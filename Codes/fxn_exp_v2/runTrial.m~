function [run, el] = runTrial(el, run, itrial, iblock, nTrials)
% do NOT delete design!!

global constant keys scr visual params response confidence timing
% do NOT global 'design' because it's huge

flagSimulate = constant.flagSimulate;

%------------------%
prepareOneTrial_SX
%------------------%

tStamp = GetSecs;

%% start the trial by displaying PH and fixation
fixRad = 5;
Screen('FillOval', scr.main, [0 0 0], [scr.xres/2-fixRad, scr.yres/2-fixRad, scr.xres/2+fixRad, scr.yres/2+fixRad]);

ELmessage_start = sprintf(' B%d-T%d [L%d-N%d-S%d]', iblock, itrial, run.targetLoc, run.iNoise, run.stair);
for iLoc = 1:params.nLoc_PH% SX_v2
    drawPlaceHolders(scr.main, visual.neutral, patchRect(iLoc,:),params.lengthPlaceHolder,params.patchsiz,params.offsetPosPlaceHolder,params.widthPlaceHolder)
end
% if run.scue==2; drawEndoCue(visual.neutral,[cxm cym], run.targetLoc); end
tFixON = Screen('Flip', scr.main);

%% eyelink
if constant.EYETRACK% SX
    
    %     Eyelink('command','draw_box %d %d %d %d 15', scr.centerX-visual.fixCheckRad, scr.centerY-visual.fixCheckRad, scr.centerX+visual.fixCheckRad, scr.centerY+visual.fixCheckRad);
    rd_eyeLink('trialstart', scr.main, {el, itrial, scr.centerX, scr.centerY, visual.fixCheckRad ,'a random message'});
end
WaitSecs(.01);
if constant.demo, pause;
    procedure = Screen('GetImage', scr.main);
    imwrite(procedure, 'procedure_fix.jpg')
end

%% stim (OREO) and PH (with bolden PH as resp cue)
% if constant.EYETRACK, Eyelink('message', 'EVENT_Fixation'); end % AB
KeyIsDown=0;
% tic
while ~breakIt
    if ~noiseSequenceOn(countFrame) && tStamp > (tFixON + run.fixDur - scr.fd)
        % placeholders
        for iLocPH = 1:params.nLoc_PH% SX
            drawPlaceHolders(scr.main, colPlaceHolder{iLocPH,countFrame}, patchRect(iLocPH,:), ...
                params.lengthPlaceHolder, params.patchsiz, params.offsetPosPlaceHolder, wdtPlaceHolder{iLocPH,countFrame})
        end
        % stim textures
        for iLoc = 1:params.nLoc_PH
            Screen('DrawTexture', scr.main, gaborTexture(iLoc,countFrame),[], gaborRect(iLoc,:)); % AB
        end
        tNoiseON(countFrame) = Screen('Flip', scr.main);
        
        
        procedure = Screen('GetImage', scr.main);
        imwrite(procedure, sprintf('procedure_count%d.jpg', countFra))

        %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
        if constant.demo
            % Pause at every frame while Gabor is present
            if (countFrame >= sum(nFramesStim(1:iframe_GaborOnset-1))+1) && (countFrame <= sum(nFramesStim(1:iframe_GaborOnset))+1)
                pause % SX
                procedure = Screen('GetImage', scr.main);
                imwrite(procedure, 'procedure_noisyGabor.jpg')
            end % SX
        end
        %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
        
        if constant.EYETRACK, Eyelink('message', 'EVENT_NoiseIsOn'); end
        noiseSequenceOn(countFrame) = 1;
        countFrame = countFrame+1;
        
    elseif ~fixCheckOff && tStamp > (tFixON + run.fixDur - scr.fd)% no need to fixate
        
        for iLocPH = 1:params.nLoc_PH% SX
            drawPlaceHolders(scr.main, colPlaceHolder{iLocPH,end}, patchRect(iLocPH,:), ...
                params.lengthPlaceHolder, params.patchsiz, params.offsetPosPlaceHolder, wdtPlaceHolder{iLocPH,end})
        end
        tfixCheckOFF = Screen(scr.main,'Flip');
        if constant.EYETRACK, Eyelink('message', 'EVENT_Gabor_RespCue_IsON'); end
        WaitSecs(run.bufferDur); % BUFFER TIME
        makeBeep(params.freqNeutral, .1) %SX, go cue
        
        fixCheckOff = 1;
    end
    
    % check eye position
    notBREAK=1;
    if constant.EYETRACK% SX
        notBREAK = rd_eyeLink('fixcheck', scr.main, {scr.centerX, scr.centerY, visual.fixCheckRad}); % SX
    end
    if ~notBREAK && ~fixCheckOff
        breakIt = 1;
        DrawFormattedText(scr.main, sprintf('Please fixate'),'center', 'center'); Screen('Flip', scr.main); WaitSecs(.5);%SX
    elseif fixCheckOff, breakIt = 2;
    end
    
    % check response before response cue
    if ~constant.demo
        [KeyIsDown] = KbCheck;
        if KeyIsDown
            breakIt=1;
            DrawFormattedText(scr.main, sprintf('Please respond after the go cue!'),'center', 'center'); Screen('Flip', scr.main); WaitSecs(.5);%SX
        end
    end
    tStamp = GetSecs;
end % while ~breakIt
% fprintf('\n')
% toc
if constant.EYETRACK, Eyelink('message', 'EVENT_StimOff'); end
if constant.demo, pause,
    procedure = Screen('GetImage', scr.main);
    imwrite(procedure, 'procedure_PH.jpg')
end

%% after stim presentation
for iLocPH = 1:params.nLoc_PH% SX
    drawPlaceHolders(scr.main, colPlaceHolder{iLocPH,end}, patchRect(iLocPH,:), ...
        params.lengthPlaceHolder, params.patchsiz, params.offsetPosPlaceHolder, wdtPlaceHolder{iLocPH,end})
end
Screen('Close', gaborTexture);

switch breakIt
    case 1
        % data = 'fixBreak';
        % Eyelink('command','draw_text 100 100 42 Fixation break');
        run.fixBreak=1;
    case 2
        % get response
        run.fixBreak=0;
        
        if flagSimulate, keyPress = 1;tRes=0;
        else, keyPress=0; while ~keyPress, [keyPress, tRes] = getKey_SX(keyPress); end % AB
        end
        % record a minimum of td.minKey sec after displacement
        % WaitSecs(tDis + td.minKey - GetSecs);
        WaitSecs(run.afterKeyDur);
        
        % for iLoc = 1:params.nLoc % AB
        for iLocPH = 1:params.nLoc_PH% SX
            drawPlaceHolders(scr.main,visual.neutral,patchRect(iLocPH,:),params.lengthPlaceHolder,params.patchsiz,params.offsetPosPlaceHolder,params.widthPlaceHolder)
        end
        % Screen(scr.main,'DrawingFinished');
        tClr = Screen(scr.main,'Flip');
        
        if constant.EYETRACK, Eyelink('message', 'EVENT_ClearScreen (resp given)'); end
        
        %% timing & RT
        timing(iblock).fixDur(itrial) = tNoiseON(1)-tFixON;
        timing(iblock).fixNoise(itrial) = tNoiseON(1+sum(nFramesStim(1)))-tNoiseON(1);
        timing(iblock).preCueDur1(itrial) = tNoiseON(1+sum(nFramesStim(1:2)))-tNoiseON(1+sum(nFramesStim(1)));
        timing(iblock).preCueDur2(itrial) = tNoiseON(1+sum(nFramesStim(1:3)))-tNoiseON(1+sum(nFramesStim(1:2)));
        timing(iblock).ISIDur(itrial) = tNoiseON(1+sum(nFramesStim(1:4)))-tNoiseON(1+sum(nFramesStim(1:3)));
        timing(iblock).stimDur(itrial) = tNoiseON(1+sum(nFramesStim(1:5)))-tNoiseON(1+sum(nFramesStim(1:4)));
        timing(iblock).postISIDur(itrial) = tfixCheckOFF-tNoiseON(1+sum(nFramesStim(1:5)));
        response(iblock).rt(itrial) = tRes - tfixCheckOFF;
        run.rt = response(iblock).rt(itrial);
        
        %% check response and give feedback
        % get report of response and confidence
        [c,r] = find(keyPress == keys.respButtons);
        if length(r)>1 % abort the trial if more than one keys are pressed concurrently
            run.fixBreak=1;
            DrawFormattedText(scr.main, sprintf('Please press only ONE key'),'center', 'center'); Screen('Flip', scr.main); WaitSecs(.5);%SX
            return
        end
        %%%%%% simulate resp %%%%%%
        if flagSimulate, SX_simulateResp, end % produce c and r % delete
        %%%%%%%%%%%%%%%%%%%%
        response(iblock).oriResp(itrial) = r(1); run.oriResp = r(1);
        c = 2;
        %         response(iblock).confidence(itrial) = c(1); run.confidence=c(1);
        
        %% play auditory feedback
        switch c, case 2, volume = params.amp; case 1, volume=params.amp/5; end % higher confidence, higher volume
        if response(iblock).oriResp(itrial) == run.stimOri
            response(iblock).iscor(itrial) = 1;
            makeBeep(params.freqCorrect , .1, volume) %SX
        else
            response(iblock).iscor(itrial) = 0;
            makeBeep(params.freqWrong , .1, volume) %SX
        end
        %% print confidence
        %         fprintf(' [confidence = %s]\n', constant.namesConfidence{run.confidence})
        run.oriResp = response(iblock).oriResp(itrial); % AB
        run.cor = response(iblock).iscor(itrial); % AB
        % td.cor(itrial) = response(iblock).iscor(itrial); % SX
        
        %% update staircase
        %         if any(constant.expMode==[1,5]) || any(run.dataMode == [1,3])
        if flag_updateStair
            params.UD{run.targetLoc, iNoise, run.stair} = ...
                PAL_AMUD_updateUD(params.UD{run.targetLoc, iNoise, run.stair}, run.cor);
            % adjust step size at 10th and 20th trial (depending on the response correctness)
            if run.cor, stairStep = params.stairStep_down; else, stairStep = params.stairStep_up; end
            if length(params.UD{run.targetLoc, iNoise, run.stair}.response)==10
                params.UD{run.targetLoc, iNoise, run.stair}.stepSizeUp = stairStep(2);
                params.UD{run.targetLoc, iNoise, run.stair}.stepSizeDown = stairStep(2);
            elseif length(params.UD{run.targetLoc, iNoise, run.stair}.response)==20
                params.UD{run.targetLoc, iNoise, run.stair}.stepSizeUp = stairStep(3);
                params.UD{run.targetLoc, iNoise, run.stair}.stepSizeDown = stairStep(3);
            end
        end
        
        if constant.expMode==5
            switch run.dataMode
                case 1, params.UD1_newNoiseSD = params.UD;
                case 3, params.UD3_newLoc = params.UD;
            end
        end
        
        
        % print trial info
        if constant.expMode~=5, run.dataMode=99; end
        fprintf('\nBlock%d Trial%d/%d: DataMode%d; istair%d, Loc%d, signal cst=%.0f%%, noise SD=%.2f\n      ORI=%d // answer = %d, corr = %d\n', ...
            run.iblock, run.itrial, nTrials, run.dataMode, run.stair, run.targetLoc, run.stimContrast*100, run.extNoiseLvl, run.stimOri, run.oriResp, run.cor)
        %         pause
end % switch breakIt

clear gaborTexture stimImg noiseImg noiseImg_ colPlaceHolder wdtPlaceHolder% to save space


if constant.demo, pause, end

% Screen('Close');
% clc
% if constant.EYETRACK, Eyelink('message', 'TRIAL_END B%d-T%d [break%d]', iblock, itrial, run.fixBreak); end
